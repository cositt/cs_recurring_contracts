<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="mail_template_contract_signed_customer_copy" model="mail.template">
            <field name="name">Contrato Cositt: copia firmada para el cliente</field>
            <field name="model_id" ref="model_cositt_subscription_contract"/>
            <field name="subject">{{ object.company_id.name }}: copia de su contrato firmado — {{ object.name }}</field>
            <field name="email_to">{{ object.partner_id.email }}</field>
            <field name="body_html" type="html">
                <div style="padding:16px;font-family:sans-serif;">
                    <p>Hola {{ object.partner_id.name or 'Cliente' }},</p>
                    <p>Adjuntamos la <strong>constancia de aceptación</strong> del contrato <strong>{{ object.name }}</strong>.</p>
                    <p style="color:#666;font-size:12px;">Este mensaje se envía de forma automática tras la firma en el portal.</p>
                    <p>Saludos,<br/>{{ object.company_id.name }}</p>
                </div>
            </field>
        </record>
    </data>
</odoo>
