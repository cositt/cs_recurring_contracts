<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="product_template_form_view_cositt" model="ir.ui.view">
        <field name="name">product.template.form.cositt</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">
            <!-- Información general: visible junto a tipo de producto (requiere Ventas activado) -->
            <xpath expr="//group[@name='group_general']" position="inside">
                <field name="cositt_recurring_contract" invisible="not sale_ok"/>
                <field name="cositt_contract_sale_type" invisible="not sale_ok or not cositt_recurring_contract"
                    widget="radio" options="{'horizontal': true}"/>
            </xpath>
        </field>
    </record>
</odoo>
